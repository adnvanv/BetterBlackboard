# Copy to .env and fill in. chmod 600 .env on the VPS.
BLACKBOARD_URL=https://blackboard.your-school.edu
BLACKBOARD_USER=your_username
BLACKBOARD_PASS=your_password

# Optional overrides
BB_DB_PATH=betterblackboard.db
BB_STORAGE_STATE=storage_state.json
BB_HEADLESS=true
BB_SCRAPE_CONCURRENCY=3

# Set to a long random string to enable the /api/admin/session upload endpoint
# (used by the login_client/ GUI to push fresh storage_state.json from your
# laptop over Tailscale). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable the endpoint entirely.
BB_UPLOAD_TOKEN=

# Daily auto-scrape (cron syntax: minute hour day month day-of-week).
# Default: every day at 5am local time. Empty string disables it.
BB_SCHEDULE=0 5 * * *
BB_TIMEZONE=America/New_York
